# Plantilla de secrets.toml — copiar a .streamlit/secrets.toml (NUNCA subir el
# archivo real a git) o pegar el mismo contenido en el panel de Streamlit
# Community Cloud (Settings → Secrets).
#
# Si NO se configuran las credenciales de Google, la app arranca sola en
# MODO DEMO con datos sintéticos — útil para validar la UI antes de conectar
# el Sheet real.

# Contraseña compartida del equipo directivo (password gate simple).
APP_PASSWORD = "cambia-esto-por-una-contraseña-fuerte"

# ID del Google Sheet "CRM Comercial CEA" (se saca de la URL del Sheet:
# https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit)
SHEET_ID = "pega-aqui-el-id-del-sheet"

# Credenciales del Service Account de Google Cloud con acceso de lectura al
# Sheet (compartir el Sheet con el campo "client_email" de abajo).
# Se descargan como JSON al crear la key del service account en Google Cloud
# Console → IAM y administración → Cuentas de servicio → Claves → Agregar clave.
[gcp_service_account]
type = "service_account"
project_id = "tu-proyecto-gcp"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "nombre@tu-proyecto-gcp.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
